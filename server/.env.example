MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?appName=<appName>
# REQUIRED in production (>= 32 chars) — the server refuses to start without it.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
PORT=3000
NODE_ENV=development
CLIENT_URL=https://your-frontend.onrender.com
OPENAI_API_KEY=sk-...

# ── Google OAuth (sign-in) ──────────────────────────────────────────────
# Create an OAuth 2.0 Client ID (type: Web application) in Google Cloud Console.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Public origin the browser uses to reach the app. Used to build the OAuth
# redirect URI (<APP_BASE_URL>/api/auth/google/callback), which must be listed
# as an Authorized redirect URI in the Google client.
#   dev:  http://localhost:5173
#   prod: https://your-app.onrender.com
APP_BASE_URL=http://localhost:5173
